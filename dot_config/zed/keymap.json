// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  /////////////////////////////////////////////////////////////////////////////
  // PANES
  /////////////////////////////////////////////////////////////////////////////

  // Pane Navigation
  {
    "context": "Workspace || (Editor && vim_mode == normal)",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",

      "ctrl-shift-h": "workspace::MovePaneLeft",
      "ctrl-shift-j": "workspace::MovePaneDown",
      "ctrl-shift-k": "workspace::MovePaneUp",
      "ctrl-shift-l": "workspace::MovePaneRight",
    },
  },

  // Editor Pane Management
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space |": "pane::SplitRight",
      "space \\": "pane::SplitLeft",
      "space -": "pane::SplitUp",
      "space _": "pane::SplitDown",
    },
  },

  // Toggle Docks
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space p h": "workspace::ToggleLeftDock",
      "space p l": "workspace::ToggleRightDock",
    },
  },

  // Project Panel
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space e": "pane::RevealInProjectPanel",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "space e": "project_panel::ToggleFocus",
    },
  },

  // Git Panel
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space g e": "git_panel::ToggleFocus",
    },
  },

  // Terminal Panel
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "terminal_panel::Toggle",
    },
  },

  // Tab Navigation
  {
    "context": "Pane && os == macos",
    "bindings": {
      // "cmd-{": "pane::ActivatePreviousItem",
      // "cmd-}": "pane::ActivateNextItem",
      "ctrl-alt-cmd-shift-h": "pane::ActivatePreviousItem",
      "ctrl-alt-cmd-shift-l": "pane::ActivateNextItem",
    },
  },
  {
    "context": "SettingsWindow && os == macos",
    "bindings": {
      // "cmd-{": "settings_editor::FocusPreviousFile",
      // "cmd-}": "settings_editor::FocusNextFile",
      "ctrl-alt-cmd-shift-h": "settings_editor::FocusPreviousFile",
      "ctrl-alt-cmd-shift-l": "settings_editor::FocusNextFile",
    },
  },

  // Editor Tab Management
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space w d": "pane::CloseAllItems", // Neovim: close window

      "space b d": "pane::CloseActiveItem", // Neovim: close buffer
      "space b shift-d": "pane::ReopenClosedItem", // Neovim: reopen buffer
      "space b o": "pane::CloseOtherItems", // Neovim: close other buffers
    },
  },

  // Override defaults
  {
    "context": "(Editor && vim_mode == insert) || TabSwitcher",
    "bindings": {
      "ctrl-h": "editor::Backspace",
    },
  },
]
